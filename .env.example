# Copy this file to .env and fill in your values
# .env is gitignored and should NEVER be committed

# Flask environment (development / production)
FLASK_ENV=development
FLASK_DEBUG=1

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your-strong-secret-key-here

# MySQL connection string
DATABASE_URL=mysql+pymysql://root:MYSQL%40123@localhost:3306/InterviewPro

# JWT token expiration in hours (default: 24)
JWT_EXPIRATION_HOURS=24

# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Docker Compose: MySQL root password
MYSQL_ROOT_PASSWORD=MYSQL%40123
